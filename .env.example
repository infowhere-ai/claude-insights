# claude-insights environment variables
# Copy to .env and adjust as needed. All variables are optional.

# Root directory scanned for Claude Code projects
# Default: auto-detected from the git worktree containing this repo
# PROJECTS_ROOT=/home/user/desenvolvimento

# Claude Code data directory (where session JSONL files are stored)
# Default: ~/.claude/projects
# CLAUDE_PROJECTS_DIR=/home/user/.claude/projects

# Claude Code home directory
# Default: ~/.claude
# CLAUDE_HOME=/home/user/.claude

# SQLite database path for session/agent persistence
# Default: ~/.claude/claude-insights.db
# CLAUDE_INSIGHTS_DB=/home/user/.claude/claude-insights.db

# Polling interval for project status files (seconds)
# Default: 0.5
# POLL_INTERVAL=0.5

# Project discovery interval (seconds)
# Default: 60.0
# DISCOVERY_INTERVAL=60.0

# JSONL session file active window (seconds)
# Default: 60.0
# JSONL_ACTIVE_SECONDS=60.0

# CORS allowed origins regex (for network deployments behind a proxy)
# Default: https?://(localhost|127\.0\.0\.1)(:\d+)?
# CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# Build metadata (injected by CI — do not set manually)
# BUILD_DATE=2026-05-01
